        - function _resampling_summary(estimate, replicates, level)
        8     variance = _sample_variance(replicates)
        8     alpha = (1 - float(level)) / 2
        8     return (
        -         estimate=estimate,
        -         variance=variance,
        -         stderr=sqrt(max(variance, 0.0)),
        -         level=float(level),
        -         lower=_sample_quantile(replicates, alpha),
        -         upper=_sample_quantile(replicates, 1 - alpha),
        -         replicates=replicates,
        -     )
        - end
        - 
        8 function _sample_variance(values)
        8     n = length(values)
        8     n > 1 || throw(ArgumentError("at least two values are required"))
       16     mean_value = sum(values) / n
      110     return sum(value -> (value - mean_value)^2, values) / (n - 1)
        - end
        - 
       16 function _sample_quantile(values, probability)
       20     sorted = sort(collect(values))
       16     n = length(sorted)
       16     n > 0 || throw(ArgumentError("at least one value is required"))
       16     position = 1 + (n - 1) * probability
       16     lower_index = floor(Int, position)
       16     upper_index = ceil(Int, position)
       16     lower_index == upper_index && return sorted[lower_index]
       16     weight = position - lower_index
       16     return (1 - weight) * sorted[lower_index] + weight * sorted[upper_index]
        - end
