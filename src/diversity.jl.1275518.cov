      131     entropy_value = _shannon_entropy(index.estimator, counts, n, index.base)
      131     if quantity === :entropy
       83         return entropy_value
       48     elseif quantity === :diversity
       48         return index.base^entropy_value
        -     else
        0         throw(ArgumentError("quantity must be :entropy or :diversity"))
        -     end
        - end
